  "clients": [
    {
      "clientId": "bss-ordering",
      "name": "product-ordering machine identity (client credentials; dev secret)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "ordering-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "bss-billing",
      "name": "billing machine identity (client credentials; dev secret)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "billing-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "bss-console",
      "name": "Catalog admin console (SPA, authorization code + PKCE)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://console.nova.localhost:8080/*",
        "http://localhost:8080/console/*"
      ],
      "webOrigins": [
        "http://console.nova.localhost:8080",
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "bss-storefront",
      "name": "Self-service storefront channel (SPA, authorization code + PKCE)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/shop/*",
        "http://shop.nova.localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://shop.nova.localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "bss-demo",
      "name": "BSS demo client (password grant, local development only)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false
    },
    {
      "clientId": "bss-csr",
      "name": "CSR console (assisted channel; SPA, authorization code + PKCE)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://csr.nova.localhost:8080/*",
        "http://localhost:8080/csr/*"
      ],
      "webOrigins": [
        "http://csr.nova.localhost:8080",
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "org",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "org",
            "claim.name": "org",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "bss-user-admin",
