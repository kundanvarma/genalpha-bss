{
  "realm": "bss",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "resetPasswordAllowed": true,
  "defaultRoles": ["customer"],
  "roles": {
    "realm": [
      { "name": "catalog:read" },
      { "name": "catalog:write" },
      { "name": "ordering:read" },
      { "name": "ordering:write" },
      { "name": "inventory:read" },
      { "name": "inventory:write" },
      { "name": "party:read" },
      { "name": "party:write" },
      {
        "name": "customer",
        "description": "Party-scoped self-service customer: services restrict reads/writes to the token subject's own resources",
        "composite": true,
        "composites": {
          "realm": [
            "catalog:read",
            "ordering:read", "ordering:write",
            "inventory:read",
            "party:read", "party:write"
          ]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "bss-ordering",
      "name": "product-ordering machine identity (client credentials; dev secret)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "ordering-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "bss-console",
      "name": "Catalog admin console (SPA, authorization code + PKCE)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:8080/console/*"],
      "webOrigins": ["http://localhost:8080"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "bss-storefront",
      "name": "Self-service storefront channel (SPA, authorization code + PKCE)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:8080/shop/*"],
      "webOrigins": ["http://localhost:8080"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "bss-demo",
      "name": "BSS demo client (password grant, local development only)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false
    }
  ],
  "users": [
    {
      "username": "service-account-bss-ordering",
      "enabled": true,
      "serviceAccountClientId": "bss-ordering",
      "realmRoles": ["catalog:read", "party:read", "inventory:write"]
    },
    {
      "username": "demo",
      "enabled": true,
      "email": "demo@bss.local",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "demo", "temporary": false }
      ],
      "realmRoles": [
        "catalog:read", "catalog:write",
        "ordering:read", "ordering:write",
        "inventory:read", "inventory:write",
        "party:read", "party:write"
      ]
    }
  ]
}
