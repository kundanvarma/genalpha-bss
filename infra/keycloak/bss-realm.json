{
  "realm": "bss",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "catalog:read" },
      { "name": "catalog:write" },
      { "name": "ordering:read" },
      { "name": "ordering:write" },
      { "name": "inventory:read" },
      { "name": "inventory:write" },
      { "name": "party:read" },
      { "name": "party:write" }
    ]
  },
  "clients": [
    {
      "clientId": "bss-demo",
      "name": "BSS demo client (password grant, local development only)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "demo", "temporary": false }
      ],
      "realmRoles": [
        "catalog:read", "catalog:write",
        "ordering:read", "ordering:write",
        "inventory:read", "inventory:write",
        "party:read", "party:write"
      ]
    }
  ]
}
