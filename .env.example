# genalpha-bss — injectable configuration
#
# Copy to .env (git-ignored) and set what you need. EVERY value has a
# dev default baked into docker-compose.yml so a fresh clone runs with
# no .env at all — these are the injection points a real deployment
# overrides. In Kubernetes the same names arrive as Secrets (see
# docs/hardening.md); nothing below should ever be committed with a
# real value.

# ---- infrastructure credentials ----
POSTGRES_PASSWORD=postgres            # the one Postgres; also the migration user
KEYCLOAK_ADMIN_PASSWORD=admin         # Keycloak master realm admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- deployment seams ----
CONTENT_STORE=in-row                  # in-row | s3 | azure-blob (document service)
PAYMENT_PSP=mock                      # mock | stripe
STRIPE_SECRET_KEY=                    # only when PAYMENT_PSP=stripe
PORTING_GATEWAY=mock                  # NP gateway adapter
PORTING_AUTO_COMPLETE_SECONDS=0       # dev clock; 0 = explicit cutover

# ---- AI (host tenant defaults; per-tenant values live in infra/tenants/tenants.yml) ----
AI_PROVIDER=stub                      # stub | openai-compatible | anthropic
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# ---- gateway rate limits (the wide ring) ----
GLOBAL_RATE_CAPACITY=1200             # requests per window, per subject/client/IP
GLOBAL_RATE_WINDOW_MS=60000

# Per-tenant secrets (ESP keys, bank/DNC/market tokens, per-tier AI keys)
# are ${ENV:default} seams in infra/tenants/tenants.yml — set the ENV name
# a tenant block references, never edit a real value into the file.
